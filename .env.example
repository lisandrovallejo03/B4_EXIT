# B4_EXIT — Environment template
# Copy to .env and fill in. .env is gitignored.

# Deploy: Vercel uses base /. GitHub Pages: set VITE_BASE_PATH=/B4_EXIT/ (match repo name).
# VITE_BASE_PATH=/

# Contact: email where meeting links are sent (REUNIONES_CONTACTO module)
VITE_CONTACT_EMAIL=""

# Transport (CABA): API URL and credentials for real-time transport data
# Dev: use Vite proxy so VITE_CABA_API_URL="/api-caba"
VITE_CABA_API_URL="/api-caba"
VITE_CABA_CLIENT_ID=""
VITE_CABA_CLIENT_SECRET=""
